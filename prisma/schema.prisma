generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserModel {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  hasPassword String   @map("hash_password")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  projects ProjectModel[]

  createdTasks  TaskModel[]    @relation("TaskCreator")
  executorTasks TaskModel[]    @relation("TaskExecutor")
  timeLogs      TimeLogModel[]

  @@map("users")
}

model ProjectModel {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId Int       @map("user_id")
  user   UserModel @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks TaskModel[]

  @@map("projects")
}

model TaskModel {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime @map("due_date")

  status      TaskStatus @default(CREATED)
  completedAt DateTime?  @map("completed_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  projectId Int          @map("project_id")
  project   ProjectModel @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createUserId Int       @map("create_user_id")
  creator      UserModel @relation("TaskCreator", fields: [createUserId], references: [id])

  executorUserId Int?       @map("executor_user_id")
  executor       UserModel? @relation("TaskExecutor", fields: [executorUserId], references: [id])

  timeLogs TimeLogModel[]

  @@map("tasks")
}

model TimeLogModel {
  id         Int       @id @default(autoincrement())
  startedAt  DateTime  @default(now()) @map("started_at") 
  endedAt    DateTime? @map("ended_at")
  durationMs Int?      @map("duration_ms")

  taskId Int       @map("task_id")
  task   TaskModel @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId Int       @map("user_id")
  user   UserModel @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("time_logs")
}

enum TaskStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
}
